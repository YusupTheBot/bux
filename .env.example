# Copy to .env or pass as env vars to install.sh.

# Local Chrome DevTools endpoint used by bux-browser-keeper.
BUX_CDP_URL=http://127.0.0.1:9222

# Optional: explicit Chrome/Chromium binary path if auto-detect fails.
BUX_CHROME_BIN=

# Optional: Telegram bot for texting your agent. Token from @BotFather.
TG_BOT_TOKEN=
